# MongoDB connection string (MongoDB Atlas recommended for Vercel)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/mealplanner?retryWrites=true&w=majority"

# Clerk (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Vercel Blob — OPTIONAL. If unset, the meal form falls back to pasting an image URL.
# Create a Blob store in your Vercel project; the token is added automatically on Vercel.
BLOB_READ_WRITE_TOKEN=""

# Meal autofill — OPTIONAL. Powers the "Autofill from title" button in the meal form.
# Unsplash (https://unsplash.com/developers) — suggests a photo for the meal title.
UNSPLASH_ACCESS_KEY=""
# Spoonacular (https://spoonacular.com/food-api) — suggests ingredients, instructions,
# cuisine and veg/non-veg. Without it, diet/cuisine still fall back to a keyword heuristic.
SPOONACULAR_API_KEY=""

# YouTube recipe import — OPTIONAL. Powers "Import from YouTube" in the meal form.
# Google Gemini (https://aistudio.google.com/apikey) — transcribes the video and
# extracts the recipe title, ingredients, instructions, cuisine and veg/non-veg.
GOOGLE_GENERATIVE_AI_API_KEY=""
